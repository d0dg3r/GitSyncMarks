  },
  "help_shortcutNotSet": {
    "message": "未设置"
  },
  "help_debugLogTitle": {
    "message": "调试日志"
  },
  "help_debugLogDesc": {
    "message": "在\"同步\"选项卡中启用，可记录详细的同步诊断信息 — 差异、合并决策和提交哈希。导出日志以供排查问题。"
  },
  "help_backupBookmarksDesc2": {
    "message": "导出书签（JSON）、Dashy 配置（YAML）或设置（纯 JSON / 加密 .enc）。导入书签或设置 — 加密文件将使用您的密码解密。书签导入会替换所有本地书签；设置导入会替换所有配置文件并重新加载页面。"
  },
  "help_themeAutoSaveTitle": {
    "message": "主题和自动保存"
  },
  "help_themeCycleTitle": {
    "message": "主题"
  },
  "help_themeCycleDesc": {
    "message": "点击顶部按钮循环切换：自动（系统）→ 深色 → 浅色 → 自动。图标显示当前模式。在选项页面和弹出窗口中均可使用。"
  },
  "help_autoSaveTitle": {
    "message": "自动保存"
  },
  "help_autoSaveDesc": {
    "message": "所有设置在更改时自动保存 — 没有保存按钮。更改立即生效。"
  },
  "help_whySlowTitle": {
    "message": "为什么同步有时很慢？"
  },
  "help_whySlowIntro": {
    "message": "GitSyncMarks 使用 GitHub 的 Git Data API 进行原子提交。每个更改或新增的书签文件都需要一次 API 调用。当变更较多时，耗时会累积。"
  },
  "help_whyAtomic": {
    "message": "所有更改都在一次原子提交中写入：要么全部成功，要么全部失败。这可以防止同步中断时出现不完整或损坏的状态。单次提交而非多次提交还能避免触发 API 频率限制，并保持 Git 历史记录的整洁。"
  },
